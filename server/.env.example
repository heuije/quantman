# 퀀트 플랫폼 서버 — 프로덕션 환경변수 예시
# 호스팅(Railway 등) 대시보드에서 아래 값을 설정한다.

# 길고 무작위한 비밀키 (JWT 서명). 예: python -c "import secrets;print(secrets.token_urlsafe(48))"
QP_SECRET_KEY=change-this-to-a-long-random-secret

# PostgreSQL 연결 (Neon 등에서 발급). 미설정 시 SQLite 사용(개발용).
QP_DB_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME

# 웹 SPA 도메인 — CORS 허용 + 페어링 안내 URL
QP_CORS_ORIGINS=https://your-web-app.vercel.app
QP_WEB_URL=https://your-web-app.vercel.app

# 액세스 토큰 유효시간(시간) — 선택
QP_ACCESS_TOKEN_HOURS=168
